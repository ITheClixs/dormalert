DORMALERT_DATABASE_PATH=./artifacts/dormalert.db
DORMALERT_ARTIFACTS_DIR=./artifacts
DORMALERT_LOG_DIR=./logs
DORMALERT_LOG_LEVEL=INFO
DORMALERT_USER_AGENT=DormAlert/0.1 (+https://example.invalid/dormalert)
DORMALERT_DETECTOR_ONLY=true
DORMALERT_ENABLE_CONSOLE_NOTIFIER=true
DORMALERT_WEBHOOK_URL=
DORMALERT_WEBHOOK_TIMEOUT_SECONDS=10
DORMALERT_EMAIL_ENABLED=false
DORMALERT_SMTP_HOST=
DORMALERT_SMTP_PORT=587
DORMALERT_SMTP_USERNAME=
DORMALERT_SMTP_PASSWORD=
DORMALERT_SMTP_STARTTLS=true
DORMALERT_EMAIL_FROM=
DORMALERT_EMAIL_TO=your-receiver@gmail.com
DORMALERT_ALERT_REMINDER_MINUTES=15

# WhatsApp alerts via the free CallMeBot relay (https://www.callmebot.com/blog/free-api-whatsapp-messages/)
# In GitHub Actions these come from repo Secrets, not this file.
DORMALERT_WHATSAPP_ENABLED=false
DORMALERT_WHATSAPP_PHONE=+41790000000
DORMALERT_WHATSAPP_APIKEY=
DORMALERT_WHATSAPP_TIMEOUT_SECONDS=15

# WhatsApp alerts via Meta's official Cloud API (see docs/whatsapp_cloud_api.md).
# Business-initiated alerts are sent through the pre-approved utility template
# named below ("DormAlert: {{1}}"). In GitHub Actions these come from repo
# Secrets, not this file.
DORMALERT_WA_CLOUD_ENABLED=false
DORMALERT_WA_CLOUD_TOKEN=
DORMALERT_WA_CLOUD_PHONE_NUMBER_ID=
DORMALERT_WA_CLOUD_TO=41790000000
DORMALERT_WA_CLOUD_TEMPLATE=dormalert_alert
DORMALERT_WA_CLOUD_TEMPLATE_LANG=en
DORMALERT_WA_CLOUD_TIMEOUT_SECONDS=15

# Telegram alerts via the official Bot API (reliable, free, instant).
# Create a bot with @BotFather to get the token; get your chat id from @userinfobot.
# In GitHub Actions these come from repo Secrets, not this file.
DORMALERT_TELEGRAM_ENABLED=false
DORMALERT_TELEGRAM_BOT_TOKEN=
DORMALERT_TELEGRAM_CHAT_ID=
DORMALERT_TELEGRAM_TIMEOUT_SECONDS=15
DORMALERT_BROWSER_HEADLESS=true
DORMALERT_BROWSER_SLOW_MO_MS=0
DORMALERT_FAILURE_ALERT_THRESHOLD=3
DORMALERT_CLOSED_ARTIFACT_RETENTION_DAYS=7
DORMALERT_CONFIRMATION_MIN_GAP_SECONDS=60
DORMALERT_OPEN_SIGNAL_FAST_PATH_STRENGTH=0.95

LIVINGSCIENCE_ENABLED=true
LIVINGSCIENCE_POLL_INTERVAL_SECONDS=300
LIVINGSCIENCE_JITTER_SECONDS=30
LIVINGSCIENCE_TIMEOUT_SECONDS=20
LIVINGSCIENCE_MAX_RETRIES=2
LIVINGSCIENCE_SUBMISSION_MODE=disabled

STUDENTVILLAGE_ENABLED=true
STUDENTVILLAGE_POLL_INTERVAL_SECONDS=180
STUDENTVILLAGE_JITTER_SECONDS=20
STUDENTVILLAGE_TIMEOUT_SECONDS=20
STUDENTVILLAGE_MAX_RETRIES=2
STUDENTVILLAGE_SUBMISSION_MODE=dry_run

STUDENTVILLAGE_SUCCESS_PHRASES=
STUDENTVILLAGE_FAILURE_PHRASES=currently all rooms are rented,we do not have a waiting list

STUDENTVILLAGE_APPLICANT_FIRSTNAME=
STUDENTVILLAGE_APPLICANT_LASTNAME=
STUDENTVILLAGE_APPLICANT_EMAIL=
STUDENTVILLAGE_APPLICANT_SECOND_EMAIL=
STUDENTVILLAGE_APPLICANT_ADDRESS=
STUDENTVILLAGE_APPLICANT_ZIPCODE=
STUDENTVILLAGE_APPLICANT_CITY=
STUDENTVILLAGE_APPLICANT_COUNTRY=
STUDENTVILLAGE_APPLICANT_PHONE=
STUDENTVILLAGE_APPLICANT_DOB=2000-01-01
STUDENTVILLAGE_APPLICANT_ROOMNUMBER=
STUDENTVILLAGE_APPLICANT_PARENTS=
STUDENTVILLAGE_APPLICANT_NATIONALITY=
STUDENTVILLAGE_APPLICANT_STUDENTFACULTY=
STUDENTVILLAGE_APPLICANT_SPOKEN_LANGUAGE=en
STUDENTVILLAGE_APPLICANT_GENDER=anonymous
STUDENTVILLAGE_APPLICANT_USERNAME=
STUDENTVILLAGE_APPLICANT_PASSWORD=
STUDENTVILLAGE_APPLICANT_REQUEST_RENTALDATE=--
STUDENTVILLAGE_APPLICANT_COMMENTS=
